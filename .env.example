# If your DB password contains reserved URL characters (#, !, @, :, /),
# URL-encode it first (e.g. # -> %23, ! -> %21).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rootvpn?schema=public"
NEXTAUTH_SECRET="replace_with_secure_random_secret"
NEXTAUTH_URL="http://localhost:3000"

STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

PAYMENT_PROVIDER="stripe"
# Для локального e2e без Stripe можно временно указать:
# PAYMENT_PROVIDER="mock"
APP_URL="http://localhost:3000"

THREEXUI_BASE_URL="https://panel.example.com/basepath"
THREEXUI_USERNAME="admin"
THREEXUI_PASSWORD="strong_password"
THREEXUI_INBOUND_ID="1"
3XUI_BASE_URL="https://panel.example.com"
3XUI_USERNAME="admin"
3XUI_PASSWORD="strong_password"
3XUI_INBOUND_ID="1"

RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000

# Optional secure admin bootstrap for prisma seed
ADMIN_EMAIL="admin@your-domain.com"
ADMIN_PASSWORD="replace_with_strong_password"
